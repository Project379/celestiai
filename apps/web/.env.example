# Clerk Authentication (from Clerk Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Auth URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Supabase (from Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (from Supabase Dashboard > Project Settings > Database > Connection string URI)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Stripe (Phase 7 — from Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard > Developers > Webhooks > Signing secret (created in 07-02)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Dashboard > Products > Celestia Premium > Monthly price ID
STRIPE_PRICE_MONTHLY=price_xxx
# Stripe Dashboard > Products > Celestia Premium > Annual price ID
STRIPE_PRICE_ANNUAL=price_xxx

# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
